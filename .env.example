# MLB Optimizer — Environment Variables
# Copy this file to .env for local development.
# NEVER commit .env to git — it is listed in .gitignore.

# ── Cloudflare R2 (object storage) ─────────────────────────────────────────
# Required only for the upload_to_r2.py script.
# After uploading, set R2_BASE_URL in Render and leave the keys out of Render.

# Your Cloudflare account ID (visible in the R2 dashboard URL)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API token credentials (create under R2 → Manage R2 API Tokens)
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key

# Name of the R2 bucket you created
R2_BUCKET_NAME=mlb-optimizer-data

# ── Application runtime ─────────────────────────────────────────────────────
# Public base URL of your R2 bucket (set this in Render, not locally).
# Leave empty for local development — the app will read from local data/ folder.
# Format: https://pub-<hash>.r2.dev   (from R2 → Settings → Public Access)
# Or use a custom domain: https://data.yourdomain.com
R2_BASE_URL=

# ── GoDaddy / Render (informational — set in Render dashboard, not here) ───
# PORT is automatically injected by Render. Do not set it manually.
# PORT=10000
